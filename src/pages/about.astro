---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Conoce Maldonado Eléctricos, expertos en instalaciones eléctricas seguras y profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container hero-content">

					<span class="eyebrow">
						NUESTRA EMPRESA
					</span>

					<h1>
						Experiencia, seguridad y compromiso
						en cada proyecto eléctrico.
					</h1>

					<p>
						En Maldonado Eléctricos ofrecemos soluciones eléctricas
						confiables para hogares, comercios e industrias,
						combinando experiencia técnica, materiales de calidad y
						atención personalizada.
					</p>

				</div>
			</section>

			<!-- ABOUT -->
			<section class="about">
				<div class="container about-grid">

					<div class="about-content">

						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa especializada en instalaciones,
							reparaciones y mantenimiento eléctrico. Nuestro objetivo
							es brindar soluciones seguras, eficientes y duraderas.
						</p>

						<p>
							Trabajamos en proyectos residenciales, comerciales e
							industriales con altos estándares de calidad.
						</p>

						<p>
							Cada proyecto se ejecuta con profesionalismo,
							transparencia y compromiso.
						</p>

					</div>

					<div class="about-card">

						<div class="card-icon">⚡</div>

						<h3>Comprometidos con la excelencia</h3>

						<p>
							Soluciones eléctricas modernas, seguras y eficientes
							para cada tipo de instalación.
						</p>

					</div>

				</div>
			</section>

			<!-- VALUES -->
			<section class="values">

				<div class="container">

					<div class="section-title">
						<h2>Nuestros valores</h2>
						<p>Los principios que guían cada trabajo.</p>
					</div>

					<div class="values-grid">

						<div class="value-card">
							<h3>Seguridad</h3>
							<p>Instalaciones seguras bajo normativa vigente.</p>
						</div>

						<div class="value-card">
							<h3>Calidad</h3>
							<p>Materiales certificados y trabajo profesional.</p>
						</div>

						<div class="value-card">
							<h3>Compromiso</h3>
							<p>Cumplimos tiempos y mantenemos transparencia.</p>
						</div>

					</div>

				</div>

			</section>

			<!-- STATS -->
			<section class="stats">

				<div class="container stats-grid">

					<div class="stat">
						<h3>10+</h3>
						<p>Años de experiencia</p>
					</div>

					<div class="stat">
						<h3>500+</h3>
						<p>Proyectos realizados</p>
					</div>

					<div class="stat">
						<h3>100%</h3>
						<p>Compromiso con clientes</p>
					</div>

				</div>

			</section>

			<!-- CTA -->
			<section class="cta">

				<div class="container">

					<h2>¿Necesitas un electricista profesional?</h2>

					<p>Estamos listos para ayudarte en tu próximo proyecto.</p>

					<a href="mailto:maldonadoelectricos@gmail.com" class="cta-button">
						Solicitar presupuesto
					</a>

				</div>

			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		background: linear-gradient(135deg, #111827, #1f2937);
		color: white;
		padding: 8rem 0 6rem;
		text-align: center;
	}

	.hero-content {
		max-width: 900px;
		margin: 0 auto;
	}

	.eyebrow {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
	}

	.hero h1 {
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		margin: 1rem 0;
		line-height: 1.1;
	}

	.hero p {
		color: rgba(255,255,255,0.8);
		line-height: 1.8;
	}

	/* ABOUT */
	.about {
		padding: 6rem 0;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.about-content h2 {
		font-size: 2.5rem;
		color: #111827;
		margin-bottom: 1rem;
	}

	.about-content p {
		color: #6b7280;
		line-height: 1.9;
		margin-bottom: 1rem;
	}

	.about-card {
		background: white;
		padding: 2.5rem;
		border-radius: 24px;
		box-shadow: 0 20px 40px rgba(0,0,0,0.08);
	}

	.card-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	/* VALUES */
	.values {
		padding: 6rem 0;
		background: #f8fafc;
	}

	.section-title {
		text-align: center;
		margin-bottom: 3rem;
	}

	.values-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.value-card {
		background: white;
		padding: 2rem;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
	}

	/* STATS */
	.stats {
		padding: 6rem 0;
		text-align: center;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.stat h3 {
		font-size: 3rem;
		color: #f59e0b;
	}

	/* CTA */
	.cta {
		background: #111827;
		color: white;
		text-align: center;
		padding: 6rem 0;
	}

	.cta-button {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 1rem 2rem;
		background: #f59e0b;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {
		.about-grid,
		.values-grid,
		.stats-grid {
			grid-template-columns: 1fr;
		}
	}

</style>