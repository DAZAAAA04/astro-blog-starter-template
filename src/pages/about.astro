---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Empresa de instalaciones eléctricas profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container hero-grid">

					<div class="hero-left">
						<span class="tag">NUESTRA EMPRESA</span>

						<h1>Maldonado Eléctricos</h1>

						<p>
							Soluciones eléctricas seguras, eficientes y profesionales
							para hogares, comercios e industrias.
						</p>
					</div>

					<div class="hero-right">
						<p class="side-text">
							Empresa especializada en instalaciones, mantenimiento y
							reparaciones eléctricas con enfoque en seguridad y calidad.
						</p>
					</div>

				</div>
			</section>

			<!-- ABOUT -->
			<section class="about">
				<div class="container about-grid">

					<div class="about-main">
						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa dedicada a soluciones eléctricas profesionales
							en el sector residencial, comercial e industrial.
						</p>

						<p>
							Trabajamos con responsabilidad, experiencia y materiales
							certificados para garantizar seguridad y durabilidad.
						</p>
					</div>

					<div class="about-side">
						<h3>Compromiso</h3>
						<p>
							Cada proyecto se ejecuta con orden, precisión y cumplimiento
							de normativa eléctrica vigente.
						</p>
					</div>

				</div>
			</section>

			<!-- VALUES (LIMPIO, NO CARDS) -->
			<section class="values">
				<div class="container values-grid">

					<div>
						<h2>Valores</h2>
					</div>

					<div class="values-list">
						<div>
							<strong>Seguridad</strong>
							<span>Instalaciones seguras bajo normativa.</span>
						</div>

						<div>
							<strong>Calidad</strong>
							<span>Materiales y ejecución profesional.</span>
						</div>

						<div>
							<strong>Confianza</strong>
							<span>Trabajo claro, honesto y responsable.</span>
						</div>
					</div>

				</div>
			</section>

			<!-- CTA LIMPIO (NO OSCURO SOBRE OSCURO) -->
			<section class="cta">
				<div class="container cta-grid">

					<div>
						<h2>¿Necesitas un servicio eléctrico?</h2>
						<p>
							Contáctanos para proyectos residenciales, comerciales o industriales.
						</p>
					</div>

					<div class="cta-action">
						<a href="mailto:maldonadoelectricos@gmail.com">
							Solicitar presupuesto
						</a>
					</div>

				</div>
			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #ffffff;
		color: #111827;
	}

	.container {
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		padding: 7rem 0 5rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 6rem;
		align-items: center;
	}

	.tag {
		color: #2563eb;
		font-weight: 700;
		letter-spacing: 2px;
		font-size: 0.85rem;
	}

	h1 {
		font-size: 3.5rem;
		margin: 1rem 0;
		line-height: 1.1;
	}

	p {
		color: #6b7280;
		line-height: 1.9;
		font-size: 1.05rem;
	}

	.side-text {
		border-left: 2px solid #e5e7eb;
		padding-left: 1.5rem;
	}

	/* ABOUT */
	.about {
		padding: 6rem 0;
		background: #f9fafb;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 6rem;
		align-items: start;
	}

	h2 {
		font-size: 2.2rem;
		margin-bottom: 1rem;
	}

	h3 {
		font-size: 1.3rem;
		margin-bottom: 0.5rem;
	}

	.about-side {
		border-left: 2px solid #e5e7eb;
		padding-left: 1.5rem;
	}

	/* VALUES (SIN CAJAS, SOLO LISTA LIMPIA) */
	.values {
		padding: 6rem 0;
	}

	.values-grid {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 6rem;
		align-items: start;
	}

	.values-list div {
		padding: 1rem 0;
		border-bottom: 1px solid #e5e7eb;
		display: flex;
		justify-content: space-between;
		gap: 2rem;
	}

	.values-list strong {
		color: #111827;
		min-width: 120px;
	}

	.values-list span {
		color: #6b7280;
		text-align: right;
	}

	/* CTA LIMPIO */
	.cta {
		padding: 6rem 0;
		background: #ffffff;
		border-top: 1px solid #e5e7eb;
	}

	.cta-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.cta a {
		display: inline-block;
		padding: 1rem 2rem;
		background: #2563eb;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {

		.hero-grid,
		.about-grid,
		.values-grid,
		.cta-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		h1 {
			font-size: 2.3rem;
		}

		.values-list div {
			flex-direction: column;
			align-items: flex-start;
		}

		.values-list span {
			text-align: left;
		}
	}

</style>