---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Conoce Maldonado Eléctricos, expertos en instalaciones eléctricas seguras y profesionales."
		/>
	</head>

	<body>

		<Header />

<Layout title="Nosotros | Maldonado Eléctricos">

	<section class="hero">
		<div class="container hero-content">

			<span class="eyebrow">
				NUESTRA EMPRESA
			</span>

			<h1>
				Experiencia, seguridad y compromiso
				en cada proyecto eléctrico.
			</h1>

			<p>
				En Maldonado Eléctricos ofrecemos soluciones eléctricas
				confiables para hogares, comercios e industrias,
				combinando experiencia técnica, materiales de calidad y
				atención personalizada.
			</p>

		</div>
	</section>

	<section class="about">
		<div class="container about-grid">

			<div class="about-content">

				<h2>Quiénes somos</h2>

				<p>
					Somos una empresa especializada en instalaciones,
					reparaciones y mantenimiento eléctrico. Nuestro objetivo
					es brindar soluciones seguras, eficientes y duraderas,
					adaptadas a las necesidades de cada cliente.
				</p>

				<p>
					Trabajamos tanto en proyectos residenciales como
					comerciales e industriales, manteniendo siempre altos
					estándares de calidad y cumplimiento normativo.
				</p>

				<p>
					Cada proyecto es ejecutado con profesionalismo,
					transparencia y compromiso, garantizando resultados que
					inspiran confianza.
				</p>

			</div>

			<div class="about-card">

				<div class="card-icon">
					⚡
				</div>

				<h3>Comprometidos con la excelencia</h3>

				<p>
					Desarrollamos soluciones eléctricas modernas,
					seguras y eficientes para cada tipo de instalación.
				</p>

			</div>

		</div>
	</section>

	<section class="values">

		<div class="container">

			<div class="section-title">
				<h2>Nuestros valores</h2>
				<p>
					Los principios que guían cada trabajo que realizamos.
				</p>
			</div>

			<div class="values-grid">

				<div class="value-card">
					<h3>Seguridad</h3>
					<p>
						Aplicamos las mejores prácticas y normativas para
						garantizar instalaciones seguras y confiables.
					</p>
				</div>

				<div class="value-card">
					<h3>Calidad</h3>
					<p>
						Utilizamos materiales y procedimientos que aseguran
						resultados duraderos y eficientes.
					</p>
				</div>

				<div class="value-card">
					<h3>Compromiso</h3>
					<p>
						Cumplimos con los plazos acordados y mantenemos una
						comunicación clara durante todo el proyecto.
					</p>
				</div>

			</div>

		</div>

	</section>

	<section class="stats">

		<div class="container stats-grid">

			<div class="stat">
				<h3>10+</h3>
				<p>Años de experiencia</p>
			</div>

			<div class="stat">
				<h3>500+</h3>
				<p>Proyectos realizados</p>
			</div>

			<div class="stat">
				<h3>100%</h3>
				<p>Compromiso con nuestros clientes</p>
			</div>

		</div>

	</section>

	<section class="cta">

		<div class="container">

			<h2>
				¿Necesitas un servicio eléctrico profesional?
			</h2>

			<p>
				Estamos preparados para ayudarte en tu próximo proyecto.
			</p>

			<a
				href="mailto:maldonadoelectricos@gmail.com"
				class="cta-button"
			>
				Solicitar presupuesto
			</a>

		</div>

	</section>

</Layout>

<style>

	:global(body) {
		margin: 0;
		font-family:
			Inter,
			system-ui,
			sans-serif;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */

	.hero {
		background:
			linear-gradient(
				135deg,
				#111827,
				#1f2937
			);

		color: white;

		padding:
			8rem
			0
			6rem;

		text-align: center;
	}

	.hero-content {
		max-width: 900px;
	}

	.eyebrow {
		display: inline-block;

		color: #f59e0b;

		font-weight: 700;

		letter-spacing: 2px;
	}

	.hero h1 {
		font-size:
			clamp(
				2.8rem,
				6vw,
				5rem
			);

		line-height: 1.1;

		margin:
			1rem
			0;
	}

	.hero p {
		font-size: 1.15rem;

		line-height: 1.8;

		color:
			rgba(
				255,
				255,
				255,
				0.8
			);
	}

	/* ABOUT */

	.about {
		padding:
			6rem
			0;
	}

	.about-grid {
		display: grid;

		grid-template-columns:
			1.4fr
			1fr;

		gap: 4rem;

		align-items: center;
	}

	.about-content h2 {
		font-size: 2.5rem;

		color: #111827;

		margin-bottom: 1rem;
	}

	.about-content p {
		color: #6b7280;

		line-height: 1.9;

		margin-bottom: 1rem;
	}

	.about-card {
		background: white;

		padding: 2.5rem;

		border-radius: 24px;

		box-shadow:
			0 20px 40px
			rgba(
				0,
				0,
				0,
				0.08
			);
	}

	.card-icon {
		font-size: 3rem;

		margin-bottom: 1rem;
	}

	.about-card h3 {
		font-size: 1.5rem;

		color: #111827;

		margin-bottom: 1rem;
	}

	.about-card p {
		color: #6b7280;

		line-height: 1.8;
	}

	/* VALUES */

	.values {
		padding:
			6rem
			0;

		background: #f8fafc;
	}

	.section-title {
		text-align: center;

		margin-bottom: 3rem;
	}

	.section-title h2 {
		font-size: 2.5rem;

		color: #111827;
	}

	.section-title p {
		color: #6b7280;
	}

	.values-grid {
		display: grid;

		grid-template-columns:
			repeat(
				3,
				1fr
			);

		gap: 2rem;
	}

	.value-card {
		background: white;

		padding: 2rem;

		border-radius: 20px;

		box-shadow:
			0 10px 30px
			rgba(
				0,
				0,
				0,
				0.05
			);

		transition: .3s ease;
	}

	.value-card:hover {
		transform:
			translateY(-5px);
	}

	.value-card h3 {
		color: #111827;

		margin-bottom: 1rem;
	}

	.value-card p {
		color: #6b7280;

		line-height: 1.8;
	}

	/* STATS */

	.stats {
		padding:
			6rem
			0;
	}

	.stats-grid {
		display: grid;

		grid-template-columns:
			repeat(
				3,
				1fr
			);

		gap: 2rem;

		text-align: center;
	}

	.stat {
		padding: 2rem;
	}

	.stat h3 {
		font-size: 3rem;

		color: #f59e0b;

		margin-bottom: .5rem;
	}

	.stat p {
		color: #6b7280;
	}

	/* CTA */

	.cta {
		background: #111827;

		color: white;

		text-align: center;

		padding:
			6rem
			0;
	}

	.cta h2 {
		font-size:
			clamp(
				2rem,
				5vw,
				3rem
			);

		margin-bottom: 1rem;
	}

	.cta p {
		color:
			rgba(
				255,
				255,
				255,
				0.75
			);

		margin-bottom: 2rem;
	}

	.cta-button {
		display: inline-block;

		padding:
			1rem
			2rem;

		border-radius: 999px;

		background: #f59e0b;

		color: white;

		text-decoration: none;

		font-weight: 600;

		transition: .3s ease;
	}

	.cta-button:hover {
		transform:
			translateY(-2px);
	}

	/* RESPONSIVE */

	@media (max-width: 900px) {

		.hero {
			padding:
				6rem
				0
				4rem;
		}

		.about-grid,
		.values-grid,
		.stats-grid {
			grid-template-columns: 1fr;
		}

		.about-content h2,
		.section-title h2 {
			font-size: 2rem;
		}

		.hero h1 {
			font-size: 2.8rem;
		}
	}

</style>