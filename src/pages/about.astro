---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Conoce Maldonado Eléctricos, expertos en instalaciones eléctricas seguras y profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container">

					<span class="badge">NUESTRA EMPRESA</span>

					<h1>
						Experiencia eléctrica que genera confianza
					</h1>

					<p>
						En Maldonado Eléctricos brindamos soluciones seguras,
						modernas y eficientes para proyectos residenciales,
						comerciales e industriales.
					</p>

				</div>
			</section>

			<!-- ABOUT -->
			<section class="about">
				<div class="container grid">

					<div>
						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa especializada en instalaciones,
							mantenimiento y reparación eléctrica con enfoque en
							seguridad, calidad y cumplimiento normativo.
						</p>

						<p>
							Trabajamos con un equipo técnico capacitado y materiales
							de primera calidad, garantizando resultados duraderos
							y seguros en cada proyecto.
						</p>

						<p>
							Nuestro compromiso es ofrecer un servicio confiable,
							rápido y transparente, adaptado a las necesidades de
							cada cliente.
						</p>
					</div>

					<div class="card">

						<div class="icon">⚡</div>

						<h3>Electricidad profesional</h3>

						<p>
							Seguridad, eficiencia y calidad en cada instalación.
						</p>

					</div>

				</div>
			</section>

			<!-- VALUES -->
			<section class="values">

				<div class="container">

					<h2>Nuestros valores</h2>

					<div class="cards">

						<div class="card-item">
							<h3>Seguridad</h3>
							<p>
								Cumplimos normativas y aplicamos prácticas seguras en cada trabajo.
							</p>
						</div>

						<div class="card-item">
							<h3>Calidad</h3>
							<p>
								Materiales certificados y ejecución profesional en cada proyecto.
							</p>
						</div>

						<div class="card-item">
							<h3>Confianza</h3>
							<p>
								Relación transparente con cada cliente desde inicio a fin.
							</p>
						</div>

					</div>

				</div>

			</section>

			<!-- STATS -->
			<section class="stats">

				<div class="container stats-grid">

					<div>
						<h3>10+</h3>
						<p>Años de experiencia</p>
					</div>

					<div>
						<h3>500+</h3>
						<p>Proyectos realizados</p>
					</div>

					<div>
						<h3>100%</h3>
						<p>Compromiso con el cliente</p>
					</div>

				</div>

			</section>

			<!-- CTA -->
			<section class="cta">

				<div class="container">

					<h2>¿Necesitas un electricista profesional?</h2>

					<p>
						Estamos listos para ayudarte en tu próximo proyecto.
					</p>

					<a href="mailto:maldonadoelectricos@gmail.com">
						Solicitar presupuesto
					</a>

				</div>

			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: system-ui, sans-serif;
		background: #ffffff;
		color: #111827;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		padding: 8rem 0 6rem;
		text-align: center;
		background: linear-gradient(135deg, #111827, #1f2937);
		color: white;
	}

	.badge {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
		font-size: 0.9rem;
	}

	.hero h1 {
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		margin: 1rem 0;
		line-height: 1.1;
	}

	.hero p {
		max-width: 700px;
		margin: 0 auto;
		color: rgba(255,255,255,0.8);
		font-size: 1.1rem;
		line-height: 1.8;
	}

	/* ABOUT */
	.about {
		padding: 6rem 0;
	}

	.grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	h2 {
		font-size: 2.3rem;
		margin-bottom: 1rem;
	}

	p {
		color: #6b7280;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.card {
		background: white;
		border-radius: 20px;
		padding: 2rem;
		box-shadow: 0 10px 30px rgba(0,0,0,0.08);
		border: 1px solid rgba(0,0,0,0.05);
	}

	.icon {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}

	.card h3 {
		margin-bottom: 0.5rem;
	}

	/* VALUES */
	.values {
		padding: 6rem 0;
		background: #f9fafb;
		text-align: center;
	}

	.cards {
		margin-top: 3rem;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.card-item {
		background: white;
		padding: 2rem;
		border-radius: 16px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.05);
	}

	.card-item h3 {
		margin-bottom: 0.5rem;
	}

	/* STATS */
	.stats {
		padding: 6rem 0;
		text-align: center;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.stats h3 {
		font-size: 3rem;
		color: #f59e0b;
	}

	/* CTA */
	.cta {
		background: #111827;
		color: white;
		text-align: center;
		padding: 6rem 0;
	}

	.cta a {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 1rem 2rem;
		background: #f59e0b;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {

		.grid,
		.cards,
		.stats-grid {
			grid-template-columns: 1fr;
		}

	}

</style>