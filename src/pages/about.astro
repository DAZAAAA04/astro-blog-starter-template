---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Conoce más sobre Maldonado Eléctricos."
		/>
	</head>

	<body>

		<Header />

		<main>

			<section class="hero">
				<div class="container">
					<span>NUESTRA EMPRESA</span>

					<h1>
						Experiencia, calidad y confianza
						en cada instalación eléctrica.
					</h1>

					<p>
						En Maldonado Eléctricos ofrecemos soluciones
						eléctricas profesionales para hogares,
						comercios e industrias.
					</p>
				</div>
			</section>

			<section class="about">
				<div class="container">
					<h2>Quiénes somos</h2>

					<p>
						Somos una empresa dedicada a brindar servicios
						eléctricos seguros, eficientes y adaptados a las
						necesidades de cada cliente.
					</p>

					<p>
						Nuestro compromiso es entregar trabajos de calidad,
						utilizando materiales confiables y siguiendo las
						normativas vigentes.
					</p>
				</div>
			</section>

		</main>

		<Footer />

	</body>
</html>

<style>
	.hero {
		padding: 8rem 2rem;
		text-align: center;
		background: linear-gradient(135deg, #111827, #1f2937);
		color: white;
	}

	.hero .container {
		max-width: 900px;
		margin: 0 auto;
	}

	.hero span {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
	}

	.hero h1 {
		font-size: clamp(3rem, 6vw, 5rem);
		line-height: 1.1;
		margin: 1rem 0;
	}

	.hero p {
		font-size: 1.15rem;
		line-height: 1.8;
		opacity: .85;
	}

	.about {
		padding: 6rem 2rem;
	}

	.about .container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.about h2 {
		font-size: 2.5rem;
		color: #111827;
		margin-bottom: 1.5rem;
	}

	.about p {
		color: #6b7280;
		line-height: 1.9;
		margin-bottom: 1rem;
		font-size: 1.05rem;
	}
</style>