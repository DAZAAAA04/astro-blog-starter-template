---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Empresa de instalaciones eléctricas profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container hero-grid">

					<div>
						<span class="tag">NUESTRA EMPRESA</span>

						<h1>Maldonado Eléctricos</h1>

						<p>
							Soluciones eléctricas seguras, eficientes y profesionales
							para proyectos residenciales, comerciales e industriales.
						</p>
					</div>

					<div class="hero-box">
						<h3>Servicio profesional</h3>
						<p>
							Instalaciones seguras, ordenadas y con cumplimiento normativo.
						</p>
					</div>

				</div>
			</section>

			<!-- ABOUT -->
			<section class="about">
				<div class="container split">

					<div>
						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa especializada en instalaciones eléctricas,
							mantenimiento y reparaciones.
						</p>

						<p>
							Trabajamos con seguridad, responsabilidad y materiales
							certificados.
						</p>
					</div>

					<div class="box">
						<h3>Compromiso</h3>
						<p>
							Cada proyecto se realiza con precisión y cumplimiento de normativa.
						</p>
					</div>

				</div>
			</section>

			<!-- VALUES (LISTA SIMPLE, LIMPIA) -->
			<section class="values">
				<div class="container">

					<h2>Nuestros valores</h2>

					<ul class="values-list">
						<li><strong>Seguridad:</strong> Instalaciones bajo normativa eléctrica.</li>
						<li><strong>Calidad:</strong> Materiales y trabajo profesional.</li>
						<li><strong>Confianza:</strong> Comunicación clara y cumplimiento.</li>
					</ul>

				</div>
			</section>

			<!-- CTA (FONDO CLARO PARA EVITAR PROBLEMA) -->
			<section class="cta">
				<div class="container cta-box">

					<h2>¿Necesitas un servicio eléctrico?</h2>

					<p>
						Contáctanos para tu proyecto residencial, comercial o industrial.
					</p>

					<a href="mailto:maldonadoelectricos@gmail.com">
						Solicitar presupuesto
					</a>

				</div>
			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #ffffff;
		color: #111827;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		padding: 6rem 0;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.tag {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
		font-size: 0.85rem;
	}

	h1 {
		font-size: 3rem;
		margin: 1rem 0;
	}

	p {
		color: #6b7280;
		line-height: 1.8;
	}

	.hero-box {
		border: 1px solid #e5e7eb;
		padding: 2rem;
		border-radius: 16px;
	}

	/* ABOUT */
	.about {
		padding: 5rem 0;
		background: #f9fafb;
	}

	.split {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 3rem;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.box {
		border: 1px solid #e5e7eb;
		padding: 2rem;
		border-radius: 16px;
		background: white;
	}

	/* VALUES LISTA SIMPLE */
	.values {
		padding: 5rem 0;
	}

	.values-list {
		list-style: none;
		padding: 0;
		margin-top: 2rem;
	}

	.values-list li {
		padding: 1rem 0;
		border-bottom: 1px solid #e5e7eb;
		color: #374151;
	}

	.values-list strong {
		color: #111827;
	}

	/* CTA CLARO (SIN ERROR DE CONTRASTE) */
	.cta {
		padding: 5rem 0;
		background: #f9fafb;
	}

	.cta-box {
		text-align: center;
		border: 1px solid #e5e7eb;
		padding: 3rem;
		border-radius: 20px;
		background: white;
	}

	.cta a {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 1rem 2rem;
		background: #f59e0b;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {

		.hero-grid,
		.split {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: 2.2rem;
		}
	}

</style>