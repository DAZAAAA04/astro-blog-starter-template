---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Empresa de instalaciones eléctricas profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container">

					<span class="tag">NUESTRA EMPRESA</span>

					<h1>Maldonado Eléctricos</h1>

					<p>
						Soluciones eléctricas seguras, eficientes y profesionales
						para hogares, comercios e industrias.
					</p>

				</div>
			</section>

			<!-- INFO SIMPLE -->
			<section class="info">
				<div class="container grid">

					<div class="box">

						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa especializada en instalaciones y
							mantenimiento eléctrico con enfoque en seguridad y calidad.
						</p>

						<p>
							Trabajamos con responsabilidad, materiales certificados
							y cumplimiento de normativas.
						</p>

					</div>

					<div class="box highlight">

						<h3>⚡ Profesionalismo</h3>

						<p>
							Cada proyecto se realiza con precisión, compromiso
							y atención al detalle.
						</p>

					</div>

				</div>
			</section>

			<!-- VALORES -->
			<section class="values">

				<div class="container">

					<h2>Nuestros valores</h2>

					<div class="cards">

						<div>
							<h3>Seguridad</h3>
							<p>Instalaciones seguras y normativas.</p>
						</div>

						<div>
							<h3>Calidad</h3>
							<p>Materiales y trabajo profesional.</p>
						</div>

						<div>
							<h3>Confianza</h3>
							<p>Trabajo claro y transparente.</p>
						</div>

					</div>

				</div>

			</section>

			<!-- CTA -->
			<section class="cta">

				<div class="container">

					<h2>¿Necesitas un electricista?</h2>

					<p>Contáctanos para tu próximo proyecto.</p>

					<a href="mailto:maldonadoelectricos@gmail.com">
						Solicitar presupuesto
					</a>

				</div>

			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #ffffff;
		color: #111827;
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		background: #111827;
		color: white;
		text-align: center;
		padding: 7rem 0;
	}

	.tag {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
		font-size: 0.85rem;
	}

	.hero h1 {
		font-size: 3rem;
		margin: 1rem 0;
	}

	.hero p {
		color: rgba(255,255,255,0.75);
		max-width: 700px;
		margin: 0 auto;
		line-height: 1.8;
	}

	/* INFO */
	.info {
		padding: 5rem 0;
	}

	.grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2rem;
		align-items: stretch;
	}

	.box {
		background: #f9fafb;
		padding: 2rem;
		border-radius: 16px;
	}

	.box h2 {
		margin-bottom: 1rem;
	}

	.box p {
		color: #6b7280;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.highlight {
		background: #111827;
		color: white;
	}

	.highlight p {
		color: rgba(255,255,255,0.75);
	}

	/* VALUES */
	.values {
		padding: 5rem 0;
		background: #ffffff;
		text-align: center;
	}

	.values h2 {
		margin-bottom: 2rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.cards div {
		background: #f9fafb;
		padding: 2rem;
		border-radius: 16px;
	}

	.cards h3 {
		margin-bottom: 0.5rem;
	}

	.cards p {
		color: #6b7280;
	}

	/* CTA */
	.cta {
		background: #111827;
		color: white;
		text-align: center;
		padding: 5rem 0;
	}

	.cta a {
		display: inline-block;
		margin-top: 1rem;
		padding: 1rem 2rem;
		background: #f59e0b;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {
		.grid,
		.cards {
			grid-template-columns: 1fr;
		}

		.hero h1 {
			font-size: 2.2rem;
		}
	}

</style>