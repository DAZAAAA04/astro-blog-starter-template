---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
	<head>
		<BaseHead
			title="Nosotros | Maldonado Eléctricos"
			description="Empresa de instalaciones eléctricas profesionales."
		/>
	</head>

	<body>

		<Header />

		<main>

			<!-- HERO -->
			<section class="hero">
				<div class="container hero-grid">

					<div class="hero-left">
						<span class="tag">NUESTRA EMPRESA</span>

						<h1>Maldonado Eléctricos</h1>

						<p>
							Soluciones eléctricas seguras, eficientes y profesionales
							para proyectos residenciales, comerciales e industriales.
						</p>
					</div>

					<div class="hero-right">
						<div class="info-card">
							<h3>Electricidad profesional</h3>
							<p>
								Trabajo seguro, normado y con materiales certificados.
							</p>
						</div>
					</div>

				</div>
			</section>

			<!-- ABOUT -->
			<section class="about">
				<div class="container split">

					<div>
						<h2>Quiénes somos</h2>

						<p>
							Somos una empresa especializada en instalaciones eléctricas,
							mantenimiento y reparaciones.
						</p>

						<p>
							Trabajamos con estándares profesionales, seguridad y
							responsabilidad en cada proyecto.
						</p>
					</div>

					<div class="box">
						<h3>Compromiso</h3>
						<p>
							Cada trabajo se realiza con precisión, orden y cumplimiento
							de normativa eléctrica.
						</p>
					</div>

				</div>
			</section>

			<!-- VALUES -->
			<section class="values">
				<div class="container">

					<h2>Nuestros valores</h2>

					<div class="grid-3">

						<div class="card">
							<h3>Seguridad</h3>
							<p>Instalaciones confiables y normadas.</p>
						</div>

						<div class="card">
							<h3>Calidad</h3>
							<p>Materiales y trabajo profesional.</p>
						</div>

						<div class="card">
							<h3>Confianza</h3>
							<p>Comunicación clara y cumplimiento.</p>
						</div>

					</div>

				</div>
			</section>

			<!-- CTA -->
			<section class="cta">
				<div class="container">

					<h2>¿Necesitas un servicio eléctrico?</h2>

					<p>Contáctanos para tu proyecto.</p>

					<a href="mailto:maldonadoelectricos@gmail.com">
						Solicitar presupuesto
					</a>

				</div>
			</section>

		</main>

		<Footer />

	</body>
</html>

<style>

	:global(body) {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #ffffff;
		color: #111827;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO */
	.hero {
		padding: 6rem 0;
		background: #ffffff;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.tag {
		color: #f59e0b;
		font-weight: 700;
		letter-spacing: 2px;
		font-size: 0.85rem;
	}

	h1 {
		font-size: 3.5rem;
		margin: 1rem 0;
	}

	p {
		color: #6b7280;
		line-height: 1.8;
		font-size: 1.05rem;
	}

	.info-card {
		border: 1px solid #e5e7eb;
		padding: 2rem;
		border-radius: 16px;
		background: #ffffff;
	}

	.info-card h3 {
		margin-bottom: 0.5rem;
	}

	/* ABOUT */
	.about {
		padding: 5rem 0;
		background: #f9fafb;
	}

	.split {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 3rem;
		align-items: start;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.box {
		background: #ffffff;
		border: 1px solid #e5e7eb;
		padding: 2rem;
		border-radius: 16px;
	}

	/* VALUES */
	.values {
		padding: 5rem 0;
	}

	.values h2 {
		margin-bottom: 2rem;
	}

	.grid-3 {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.card {
		border: 1px solid #e5e7eb;
		padding: 2rem;
		border-radius: 16px;
		background: #ffffff;
	}

	.card h3 {
		margin-bottom: 0.5rem;
	}

	/* CTA */
	.cta {
		padding: 5rem 0;
		background: #111827;
		color: white;
		text-align: center;
	}

	.cta p {
		color: rgba(255,255,255,0.75);
	}

	.cta a {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 1rem 2rem;
		background: #f59e0b;
		color: white;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {

		.hero-grid,
		.split,
		.grid-3 {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: 2.3rem;
		}
	}

</style>