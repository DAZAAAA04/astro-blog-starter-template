---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const projects = [
	{
		title: 'Proyecto Colegio Americano',
		category: 'ENERGÍA SOLAR',
		description:
			'Instalación de sistema de medida en media tensión 34.5kV en subestación principal.',
		image: '/colegioamericano.JPG',
	},

	{
		title: 'Proyecto PTI Trancelca',
		category: 'ENERGÍA',
		description:
			'Pruebas de factor de potencia y excitación para transformador de 120MVA.',
		image: '/pti-trancelca.JPG',
	},

	{
		title: 'Hospital Santo Tomás',
		category: 'HOSPITALES',
		description:
			'Mantenimiento preventivo y correctivo en subestación principal de 300kV.',
		image: '/hospital-santotomas.JPG',
	},

	{
		title: 'Cemex Colombia',
		category: 'INDUSTRIA',
		description:
			'Mantenimiento eléctrico, transformación y control de plantas industriales.',
		image: '/cemex-colombia.JPG',
	},

	{
		title: 'Proyecto Procaps',
		category: 'AUTOMATIZACIÓN',
		description:
			'Armado de tablero de control y fuerza para sistemas de enfriamiento industrial.',
		image: '/procaps.JPG',
	},

	{
		title: 'Sociedad Portuaria',
		category: 'MEDIA TENSIÓN',
		description:
			'Tendido e instalación de cable XLP subterráneo para sistema de anillo en media tensión.',
		image: '/sociedad-portuaria.JPG',
	},
];
---

<!doctype html>
<html lang="es">

<head>
	<BaseHead
		title={`Proyectos | ${SITE_TITLE}`}
		description={SITE_DESCRIPTION}
	/>
</head>

<body>

	<Header />

	<main>

		<!-- HERO -->
		<section class="hero">

			<div class="hero-content">

				<span class="badge">
					PROYECTOS INDUSTRIALES
				</span>

				<h1>
					Experiencia en ingeniería eléctrica real
				</h1>

				<p>
					Proyectos ejecutados en energía, industria, hospitales y
					automatización con altos estándares técnicos.
				</p>

			</div>

		</section>

		<!-- PROJECTS -->
		<section class="projects">

			<div class="section-title">
				<span>NUESTROS PROYECTOS</span>
				<h2>Soluciones ejecutadas</h2>
			</div>

			<div class="projects-grid">

				{projects.map((project) => (

					<div class="project-card">

						<img
							src={project.image}
							alt={project.title}
						/>

						<div class="project-content">

							<span class="project-tag">
								{project.category}
							</span>

							<h3>{project.title}</h3>

							<p>{project.description}</p>

						</div>

					</div>

				))}

			</div>

		</section>

	</main>

	<Footer />

</body>

</html>

<style>

	body {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #f3f4f6;
		color: #111827;
	}

	/* HERO MÁS ANCHO */
	.hero {
		width: 100%;
		padding: 4rem 2rem 5rem;
		display: flex;
		justify-content: center;
	}

	.hero-content {
		width: 100%;
		max-width: 1400px;
		background: white;
		border-radius: 28px;
		padding: 5rem 3rem;
		box-shadow: 0 20px 60px rgba(0,0,0,0.05);
		text-align: center;
	}

	/* AMARILLO (DECORACIÓN) */
	.badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		background: rgba(245, 158, 11, 0.15);
		color: #d97706;
		font-size: 0.85rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		letter-spacing: 1px;
	}

	.hero h1 {
		font-size: 3.8rem;
		line-height: 1.1;
		margin-bottom: 1rem;
	}

	.hero p {
		max-width: 800px;
		margin: 0 auto;
		font-size: 1.15rem;
		color: #6b7280;
		line-height: 1.8;
	}

	/* SECTION MÁS ANCHA */
	.projects {
		width: 100%;
		padding: 0 2rem 6rem;
		display: flex;
		justify-content: center;
	}

	.section-title {
		max-width: 1400px;
		margin: 0 auto 3rem;
	}

	.section-title span {
		color: #d97706;
		font-weight: 800;
		letter-spacing: 1px;
	}

	.section-title h2 {
		font-size: 3rem;
		margin-top: 1rem;
	}

	/* GRID MÁS ABIERTO */
	.projects-grid {
		max-width: 1400px;
		width: 100%;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 3rem;
	}

	/* CARD GRANDE Y RESPIRADA */
	.project-card {
		background: white;
		border-radius: 26px;
		overflow: hidden;
		box-shadow: 0 18px 50px rgba(0,0,0,0.06);
		transition: 0.35s ease;
	}

	.project-card:hover {
		transform: translateY(-8px);
	}

	.project-card img {
		width: 100%;
		height: 360px;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.project-card:hover img {
		transform: scale(1.06);
	}

	.project-content {
		padding: 2.2rem;
	}

	/* AMARILLO EN TAG */
	.project-tag {
		display: inline-block;
		padding: 0.45rem 1rem;
		background: rgba(245, 158, 11, 0.15);
		color: #d97706;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.project-content h3 {
		font-size: 1.6rem;
		margin-bottom: 0.8rem;
	}

	.project-content p {
		color: #6b7280;
		line-height: 1.8;
		font-size: 1.05rem;
	}

	/* RESPONSIVE */
	@media (max-width: 1100px) {

		.projects-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero-content {
			padding: 3rem 2rem;
		}

		.hero h1 {
			font-size: 2.5rem;
		}

		.section-title h2 {
			font-size: 2.2rem;
		}
	}

</style>