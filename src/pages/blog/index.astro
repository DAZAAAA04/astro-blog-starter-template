---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const projects = [
	{
		title: 'Proyecto Colegio Americano',
		category: 'ENERGÍA SOLAR',
		description:
			'Instalación de sistema de medida en media tensión 34.5kV en subestación principal.',
		image: '/colegioamericano.JPG',
	},
	{
		title: 'Proyecto PTI Trancelca',
		category: 'ENERGÍA',
		description:
			'Pruebas de factor de potencia y excitación para transformador de 120MVA.',
		image: '/pti-trancelca.JPG',
	},
	{
		title: 'Hospital Santo Tomás',
		category: 'HOSPITALES',
		description:
			'Mantenimiento preventivo y correctivo en subestación principal de 300kV.',
		image: '/hospital-santotomas.JPG',
	},
	{
		title: 'Cemex Colombia',
		category: 'INDUSTRIA',
		description:
			'Mantenimiento eléctrico, transformación y control de plantas industriales.',
		image: '/cemex-colombia.JPG',
	},
	{
		title: 'Proyecto Procaps',
		category: 'AUTOMATIZACIÓN',
		description:
			'Armado de tablero de control y fuerza para sistemas de enfriamiento industrial.',
		image: '/procaps.JPG',
	},
	{
		title: 'Sociedad Portuaria',
		category: 'MEDIA TENSIÓN',
		description:
			'Tendido e instalación de cable XLP subterráneo para sistema de anillo en media tensión.',
		image: '/sociedad-portuaria.JPG',
	},
];
---
<!doctype html>
<html lang="es">
<head>
	<BaseHead
		title="Proyectos| Maldonado Eléctricos"
	/>
</head>
<body>

	<Header />

	<main>
	<!-- HERO -->
	<section class="hero">
		<div class="container">

			<span class="badge">PROYECTOS INDUSTRIALES</span>

			<h1>Ingeniería eléctrica en campo real</h1>

			<p>
				Experiencia en energía, industria, hospitales y automatización
				con altos estándares técnicos y ejecución profesional.
			</p>

		</div>
	</section>

	<!-- PROJECTS -->
	<section class="projects">
		<div class="container">

			<div class="grid">

				{projects.map((project) => (

					<div class="card">

						<img src={project.image} alt={project.title} />

						<div class="content">

							<span class="tag">
								{project.category}
							</span>

							<h3>{project.title}</h3>

							<p>{project.description}</p>

						</div>

					</div>

				))}

			</div>

		</div>
	</section>

	</main>

	<Footer />

</body>
</html>
<style>

	body {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #f3f4f6;
		color: #111827;
	}

	main {
		width: 100%;
	}

	/* CONTENEDOR ESTABLE (CLAVE) */
	.container {
		width: 100%;
		max-width: 1300px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* HERO LIMPIO Y RESPIRADO */
	.hero {
		background: white;
		padding: 5rem 0;
		border-bottom: 1px solid #e5e7eb;
	}

	.badge {
		display: inline-block;
		background: rgba(245, 158, 11, 0.15);
		color: #d97706;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-weight: 800;
		letter-spacing: 1px;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	p {
		max-width: 800px;
		color: #6b7280;
		line-height: 1.8;
		font-size: 1.1rem;
	}

	/* GRID PROFESIONAL (NO APRETADO) */
	.projects {
		padding: 4rem 0 6rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	/* CARD PROPORCIONADA */
	.card {
		background: white;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 15px 40px rgba(0,0,0,0.06);
		transition: 0.3s ease;
	}

	.card:hover {
		transform: translateY(-6px);
	}

	.card img {
		width: 100%;
		height: 340px;
		object-fit: cover;
	}

	.content {
		padding: 2rem;
	}

	.tag {
		display: inline-block;
		background: rgba(245, 158, 11, 0.15);
		color: #d97706;
		padding: 0.4rem 0.9rem;
		border-radius: 999px;
		font-weight: 800;
		font-size: 0.8rem;
		margin-bottom: 1rem;
	}

	h3 {
		font-size: 1.5rem;
		margin-bottom: 0.8rem;
	}

	p {
		color: #6b7280;
		line-height: 1.7;
	}

	/* RESPONSIVE REAL */
	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: 2.2rem;
		}
	}

</style>