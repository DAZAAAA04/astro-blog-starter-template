---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const projects = [
	{
		title: 'Proyecto Colegio Americano',
		category: 'ENERGÍA SOLAR',
		description:
			'Instalación de sistema de medida en media tensión 34.5kV en subestación principal.',
		image: '/colegioamericano.JPG',
	},

	{
		title: 'Proyecto PTI Trancelca',
		category: 'ENERGÍA',
		description:
			'Pruebas de factor de potencia y excitación para transformador de 120MVA.',
		image: '/pti-trancelca.JPG',
	},

	{
		title: 'Hospital Santo Tomás',
		category: 'HOSPITALES',
		description:
			'Mantenimiento preventivo y correctivo en subestación principal de 300kV.',
		image: '/hospital-santotomas.JPG',
	},

	{
		title: 'Cemex Colombia',
		category: 'INDUSTRIA',
		description:
			'Mantenimiento eléctrico, transformación y control de plantas industriales.',
		image: '/cemex-colombia.JPG',
	},

	{
		title: 'Proyecto Procaps',
		category: 'AUTOMATIZACIÓN',
		description:
			'Armado de tablero de control y fuerza para sistemas de enfriamiento industrial.',
		image: '/procaps.JPG',
	},

	{
		title: 'Sociedad Portuaria',
		category: 'MEDIA TENSIÓN',
		description:
			'Tendido e instalación de cable XLP subterráneo para sistema de anillo en media tensión.',
		image: '/sociedad-portuaria.JPG',
	},
];
---

<!doctype html>
<html lang="es">

<head>
	<BaseHead
		title={`Proyectos | ${SITE_TITLE}`}
		description={SITE_DESCRIPTION}
	/>
</head>

<body>

	<Header />

	<main>

		<!-- HERO -->
		<section class="hero">

			<div class="hero-content">

				<span class="badge">PROYECTOS INDUSTRIALES</span>

				<h1>Experiencia real en ingeniería eléctrica</h1>

				<p>
					Hemos desarrollado proyectos para industria, energía,
					hospitales y automatización con altos estándares de calidad
					y seguridad.
				</p>

			</div>

		</section>

		<!-- PROJECTS -->
		<section class="projects">

			<div class="section-title">
				<span>NUESTROS PROYECTOS</span>
				<h2>Soluciones ejecutadas</h2>
			</div>

			<div class="projects-grid">

				{projects.map((project) => (

					<div class="project-card">

						<img
							src={project.image}
							alt={project.title}
						/>

						<div class="project-content">

							<span class="project-tag">
								{project.category}
							</span>

							<h3>{project.title}</h3>

							<p>{project.description}</p>

						</div>

					</div>

				))}

			</div>

		</section>

	</main>

	<Footer />

</body>

</html>

<style>

	body {
		margin: 0;
		font-family: Inter, system-ui, sans-serif;
		background: #f3f4f6;
		color: #111827;
	}

	/* HERO */
	.hero {
		max-width: 1280px;
		margin: 0 auto;
		padding: 3rem 2rem 4rem;
	}

	.hero-content {
		background: white;
		border-radius: 28px;
		padding: 4rem;
		box-shadow: 0 20px 60px rgba(0,0,0,0.05);
		text-align: center;
	}

	.badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		background: rgba(37, 99, 235, 0.1);
		color: #2563eb;
		font-size: 0.85rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		line-height: 1.1;
		margin-bottom: 1rem;
	}

	.hero p {
		max-width: 700px;
		margin: 0 auto;
		font-size: 1.1rem;
		color: #6b7280;
		line-height: 1.8;
	}

	/* SECTION */
	.projects {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 2rem 5rem;
	}

	.section-title span {
		color: #2563eb;
		font-weight: 700;
		font-size: 0.9rem;
		letter-spacing: 1px;
	}

	.section-title h2 {
		font-size: 2.8rem;
		margin-top: 1rem;
		margin-bottom: 3rem;
	}

	/* GRID */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}

	/* CARD */
	.project-card {
		background: white;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 15px 40px rgba(0,0,0,0.05);
		transition: 0.3s ease;
	}

	.project-card:hover {
		transform: translateY(-6px);
	}

	.project-card img {
		width: 100%;
		height: 300px;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.project-card:hover img {
		transform: scale(1.05);
	}

	.project-content {
		padding: 1.8rem;
	}

	.project-tag {
		display: inline-block;
		padding: 0.4rem 0.8rem;
		background: rgba(37, 99, 235, 0.1);
		color: #2563eb;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 700;
		margin-bottom: 1rem;
	}

	.project-content h3 {
		font-size: 1.4rem;
		margin-bottom: 0.8rem;
	}

	.project-content p {
		color: #6b7280;
		line-height: 1.7;
	}

	/* MOBILE */
	@media (max-width: 900px) {

		.hero-content {
			padding: 2rem;
		}

		.hero h1 {
			font-size: 2.3rem;
		}

		.section-title h2 {
			font-size: 2rem;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

</style>