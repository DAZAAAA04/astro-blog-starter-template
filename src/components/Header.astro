---
import HeaderLink from './HeaderLink.astro';
---

<header class="header">
	<nav class="nav">

		<!-- LOGO -->
		<a href="/" class="logo">
			<img src="/favicon.jpeg" alt="Logo" class="logo-image" />

			<div class="logo-text">
				<span class="logo-top">MALDONADO</span>
				<br><span class="logo-bottom">ELÉCTRICOS</span>
			</div>
		</a>

		<!-- DESKTOP LINKS -->
		<div class="links">
			<HeaderLink href="/">Servicios</HeaderLink>
			<HeaderLink href="/blog">Proyectos</HeaderLink>
			<HeaderLink href="/about">Nosotros</HeaderLink>
		</div>

		<!-- CTA -->
		<a href="mailto:maldonadoelectricos@gmail.com" class="cta">
			Contactar
		</a>

		<!-- MOBILE BTN -->
		<button class="menu-btn" id="menuBtn">☰</button>

	</nav>

	<!-- OVERLAY -->
	<div class="overlay" id="overlay"></div>

	<!-- MOBILE -->
	<div class="mobile" id="mobileMenu">

		<a href="/">Servicios</a>
		<a href="/blog">Proyectos</a>
		<a href="/about">Nosotros</a>

		<a class="mobile-cta" href="mailto:maldonadoelectricos@gmail.com">
			Contactar
		</a>

	</div>
</header>

<script>
	const menuBtn = document.getElementById('menuBtn');
	const mobileMenu = document.getElementById('mobileMenu');
	const overlay = document.getElementById('overlay');

	function toggle() {
		mobileMenu.classList.toggle('active');
		overlay.classList.toggle('active');
		document.body.classList.toggle('no-scroll');
	}

	menuBtn?.addEventListener('click', toggle);
	overlay?.addEventListener('click', toggle);

	document.querySelectorAll('.mobile a').forEach(a => {
		a.addEventListener('click', toggle);
	});
</script>

<style>

	/* HEADER BASE */
	.header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255,255,255,0.85);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid #e5e7eb;
	}

	.nav {
		max-width: 1200px;
		margin: auto;
		padding: 1rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	/* LOGO */
	.logo {
		display: flex;
		align-items: center;
		gap: 1rem;
		text-decoration: none;
	}

	.logo-image {
		width: 64px;
		height: 64px;
		object-fit: contain;
	}

	.logo-top {
		font-size: 1.1rem;
		font-weight: 800;
		color: #111827;
		letter-spacing: 1px;
	}

	.logo-bottom {
		font-size: 1rem;
		font-weight: 600;
		color: #2563eb;
	}

	/* LINKS DESKTOP */
	.links {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.links a {
		text-decoration: none;
		color: #374151;
		font-weight: 500;
		position: relative;
		padding: 0.4rem 0;
		transition: 0.2s ease;
	}

	.links a::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -4px;
		height: 2px;
		width: 0%;
		background: #2563eb;
		border-radius: 999px;
		transition: 0.3s ease;
	}

	.links a:hover {
		color: #111827;
	}

	.links a:hover::after {
		width: 100%;
	}

	/* CTA */
	.cta {
		background: #2563eb;
		color: white;
		padding: 0.75rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		transition: 0.2s ease;
	}

	.cta:hover {
		background: #1d4ed8;
		transform: translateY(-1px);
	}

	/* MENU BTN */
	.menu-btn {
		display: none;
		font-size: 1.8rem;
		background: none;
		border: none;
		cursor: pointer;
		color: #111827;
	}

	/* OVERLAY */
	.overlay {
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.4);
		opacity: 0;
		pointer-events: none;
		transition: 0.3s;
	}

	.overlay.active {
		opacity: 1;
		pointer-events: all;
	}

	/* MOBILE */
	.mobile {
		position: fixed;
		top: 0;
		right: 0;
		width: 280px;
		height: 100vh;
		background: white;
		transform: translateX(100%);
		transition: 0.3s ease;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		box-shadow: -10px 0 30px rgba(0,0,0,0.1);
	}

	.mobile.active {
		transform: translateX(0);
	}

	.mobile a {
		text-decoration: none;
		color: #111827;
		font-size: 1.1rem;
		font-weight: 500;
	}

	.mobile-cta {
		margin-top: 1rem;
		background: #2563eb;
		color: white !important;
		padding: 0.9rem;
		border-radius: 999px;
		text-align: center;
	}

	.no-scroll {
		overflow: hidden;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {
		.links,
		.cta {
			display: none;
		}

		.menu-btn {
			display: block;
		}
	}

</style>